{
    "$schema":  "https://schema.tauri.app/config/2",
    "productName":  "BharatTech",
    "version":  "0.53.0",
    "identifier":  "com.bharattech.coder",
    "build":  {
                  "beforeDevCommand":  "pnpm run dev",
                  "beforeBuildCommand":  "pnpm run build",
                  "devUrl":  "http://localhost:1420",
                  "frontendDist":  "../dist"
              },
    "app":  {
                "windows":  [
                                {
                                    "title":  "BharatTech",
                                    "width":  1460,
                                    "height":  920,
                                    "minWidth":  1080,
                                    "minHeight":  680,
                                    "resizable":  true,
                                    "decorations":  true
                                }
                            ]
            },
    "bundle":  {
                   "active":  true,
                   "targets":  [
                                   "nsis"
                               ],
                   "icon":  [
                                "icons/32x32.png",
                                "icons/128x128.png",
                                "icons/icon.ico"
                            ]
               },
    "plugins":  {
                    "deep-link":  {
                                      "desktop":  {
                                                      "schemes":  [
                                                                      "bharattech"
                                                                  ]
                                                  }
                                  }
                }
}
